"""Live multi-branch review dashboard (prototype).

Discovers every git worktree, assigns each a review port, and serves a small
control panel that shows live up/down status and lets you Start or Stop each
branch's app. Each branch runs on its own ports and its own profile, so several
run at once without clashing.

Start also launches that worktree's web-watch (same as `just dev`), so saves and
commits to ts/sass/web rebuild and browser tabs reload via the build token.
Python/backend still needs Stop/Start.

Run with `just review`, then open the printed URL. Nothing launches until you
press Start. Closing the dashboard (Ctrl-C) stops the instances it started.
"""

from __future__ import annotations

import atexit
import json
import os
import signal
import socket
import subprocess
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, urlparse

ROOT = Path(__file__).resolve().parent.parent
CONTROL_PORT = int(os.environ.get("PGREP_REVIEW_PORT", "40100"))
LOG_DIR = ROOT / "out" / "review-logs"
TMP = os.environ.get("TMPDIR", "/tmp").rstrip("/")

# n -> Popen for instances / web-watchers this dashboard launched
PROCS: dict[int, subprocess.Popen] = {}
WATCHERS: dict[int, subprocess.Popen] = {}


def worktrees() -> list[dict]:
    """[{n, name, path, port}] for every git worktree, in listing order."""
    out = subprocess.run(
        ["git", "worktree", "list", "--porcelain"],
        cwd=ROOT,
        capture_output=True,
        text=True,
        check=True,
    ).stdout
    items: list[dict] = []
    path: str | None = None
    branch: str | None = None

    def flush() -> None:
        nonlocal path, branch
        if path:
            n = len(items) + 1
            items.append(
                {"n": n, "name": branch or "detached", "path": path, "port": 40000 + n}
            )
        path, branch = None, None

    for line in out.splitlines():
        if line.startswith("worktree "):
            path = line[len("worktree ") :]
        elif line.startswith("branch "):
            branch = line[len("branch refs/heads/") :]
        elif line == "":
            flush()
    flush()
    return items


def port_up(port: int) -> bool:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.settimeout(0.15)
        return s.connect_ex(("127.0.0.1", port)) == 0


def running(n: int) -> bool:
    proc = PROCS.get(n)
    return proc is not None and proc.poll() is None


def _kill_pg(proc: subprocess.Popen | None) -> None:
    if proc is None or proc.poll() is not None:
        return
    try:
        os.killpg(os.getpgid(proc.pid), signal.SIGTERM)
    except (ProcessLookupError, PermissionError):
        pass


def _web_watch_script(worktree: str) -> Path:
    """Prefer the worktree's web-watch; fall back to the primary checkout."""
    local = Path(worktree) / "tools" / "web-watch"
    if local.is_file():
        return local
    return ROOT / "tools" / "web-watch"


def start(n: int, path: str, port: int) -> None:
    if running(n):
        return
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    env = os.environ.copy()
    # Stay bound to 127.0.0.1: browser tabs at 127.0.0.1:port reach pgrep
    # endpoints without unlocking the full API (ANKI_API_HOST=0.0.0.0 would).
    env.pop("ANKI_API_HOST", None)
    env["ANKI_API_PORT"] = str(port)
    env["QTWEBENGINE_REMOTE_DEBUGGING"] = str(8080 + n)
    env["ANKI_BASE"] = f"{TMP}/pgrep-inst-{n}"
    # Unique single-instance key, or Anki forwards to the already-running app and
    # this one exits without binding its port.
    env["ANKI_SINGLE_INSTANCE_KEY"] = f"pgrep-inst-{n}"
    # Headless: no desktop window pop-ups; view each branch in a browser tab.
    # Also tells web-watch to skip its initial build (./run already builds) and
    # only ninja qt on change so browser tabs pick up the reload token.
    env["PGREP_HEADLESS"] = "1"
    env.setdefault("PGREP_SURFACE_MODE", "exclusive")
    log = open(LOG_DIR / f"inst-{n}.log", "ab")
    # ./run exists in every worktree, so this does not depend on that branch
    # having the _review-instance recipe. Own session so we can kill the whole tree.
    PROCS[n] = subprocess.Popen(
        ["./run"], cwd=path, env=env, stdout=log, stderr=log, start_new_session=True
    )
    # Same watcher as `just dev`: rebuild web on ts/sass/web edits (incl. commits).
    watch = _web_watch_script(path)
    if watch.is_file():
        watch_log = open(LOG_DIR / f"inst-{n}-watch.log", "ab")
        WATCHERS[n] = subprocess.Popen(
            [str(watch)],
            cwd=path,
            env=env,
            stdout=watch_log,
            stderr=watch_log,
            start_new_session=True,
        )


def stop(n: int) -> None:
    _kill_pg(WATCHERS.pop(n, None))
    _kill_pg(PROCS.pop(n, None))


def stop_all() -> None:
    for n in set(PROCS) | set(WATCHERS):
        stop(n)


def show_window(port: int) -> tuple[bool, str]:
    """Ask a running headless instance to raise its product window.

    Proxied from the dashboard so the browser does not cross-origin hit mediasrv.
    """
    import urllib.error
    import urllib.request

    url = f"http://127.0.0.1:{port}/_anki/pgrepDevShowWindow"
    try:
        with urllib.request.urlopen(url, timeout=2.0) as resp:
            body = resp.read().decode("utf-8", errors="replace")
            return True, body or "ok"
    except urllib.error.HTTPError as e:
        return False, f"HTTP {e.code}"
    except Exception as e:  # noqa: BLE001 - surface any connect/timeout to the UI
        return False, str(e)


atexit.register(stop_all)


