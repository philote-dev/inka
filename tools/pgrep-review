"""


class Handler(BaseHTTPRequestHandler):
    def _send(self, code: int, body, ctype: str = "text/html; charset=utf-8") -> None:
        data = body.encode() if isinstance(body, str) else body
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self) -> None:
        path = urlparse(self.path).path
        if path == "/":
            self._send(200, PAGE)
        elif path == "/status":
            rows = [
                {**w, "up": port_up(w["port"]), "running": running(w["n"])}
                for w in worktrees()
            ]
            self._send(200, json.dumps(rows), "application/json")
        else:
            self._send(404, "not found")

    def do_POST(self) -> None:
        u = urlparse(self.path)
        n = int(parse_qs(u.query).get("n", ["0"])[0])
        by_n = {w["n"]: w for w in worktrees()}
        if u.path == "/start" and n in by_n:
            start(n, by_n[n]["path"], by_n[n]["port"])
        elif u.path == "/stop":
            stop(n)
        self._send(200, "{}", "application/json")

    def log_message(self, *_args) -> None:
        pass  # quiet


def main() -> None:
    httpd = ThreadingHTTPServer(("127.0.0.1", CONTROL_PORT), Handler)
    url = f"http://127.0.0.1:{CONTROL_PORT}/"
    print(f"pgrep review dashboard: {url}")
    print("Start branches from the page. Ctrl-C stops the dashboard and what it launched.")
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        stop_all()


if __name__ == "__main__":
    main()
