  const tb = document.getElementById('rows'); tb.innerHTML = '';
  for (const w of rows){
    const status = w.up ? 'up' : (w.running ? 'starting' : 'stopped');
    const app = 'http://127.0.0.1:' + w.port + '/pgrep';
    const lab = 'http://127.0.0.1:' + w.port + '/pgrep-lab';
    const tr = document.createElement('tr');
    tr.innerHTML =
      '<td class="name">' + w.name + '</td>' +
      '<td><code>' + w.port + '</code></td>' +
      '<td><span class="pill ' + status + '">' + status + '</span></td>' +
      '<td>' + (w.up
        ? '<a class="lab" target="_blank" href="'+app+'">app</a> · <a class="lab" target="_blank" href="'+lab+'">lab</a>'
        : '<a class="lab off">app · lab</a>') + '</td>' +
      '<td>' + (w.running
        ? '<button class="stop" onclick="act(\\'stop\\','+w.n+')">Stop</button>'
        : '<button onclick="act(\\'start\\','+w.n+')">Start</button>') + '</td>';
    tb.appendChild(tr);
