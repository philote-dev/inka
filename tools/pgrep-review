 button.stop{border-color:#e3b3b3;color:#b3261e;background:#fff5f5}
 code{font:12px ui-monospace,monospace;color:#888}
</style></head>
<body>
 <h1>pgrep review</h1>
 <p class="sub">Start a branch to serve it headless on its own port, then open it in a browser tab. Leave this tab open.</p>
 <table>
  <thead><tr><th>Branch</th><th>Port</th><th>Status</th><th>Open</th><th></th></tr></thead>
  <tbody id="rows"></tbody>
 </table>
<script>
async function refresh(){
